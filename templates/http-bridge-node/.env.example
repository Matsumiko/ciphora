CIPHORA_BRIDGE_PROVIDER=postgres
# Optional reported provider type for /health:
# external_tidb_bridge, external_cockroach_bridge, external_aiven_bridge,
# external_supabase_bridge, external_mongodb_bridge, external_firestore_bridge
CIPHORA_BRIDGE_PROVIDER_TYPE=external_cockroach_bridge
CIPHORA_BRIDGE_TOKEN=change-me-to-a-long-random-token
CIPHORA_ALLOWED_ORIGINS=https://app.ciphora.indevs.in,https://ciphora.pages.dev
CIPHORA_BRIDGE_PORT=8977

# PostgreSQL-compatible providers:
# - CockroachDB Basic
# - Aiven PostgreSQL Free Tier
# - Supabase Postgres / Supabase pooler
DATABASE_URL=replace-with-postgresql-connection-string

# TiDB Cloud / MySQL-compatible mode:
# CIPHORA_BRIDGE_PROVIDER=mysql
# DATABASE_URL=replace-with-mysql-or-tidb-connection-string

# MongoDB Atlas mode:
# CIPHORA_BRIDGE_PROVIDER=mongodb
# MONGODB_URI=replace-with-mongodb-atlas-connection-string
# MONGODB_DATABASE=ciphora_vault

# Firebase Firestore mode:
# CIPHORA_BRIDGE_PROVIDER=firestore
# FIRESTORE_PROJECT_ID=my-firebase-project
# FIRESTORE_DATABASE_ID=(default)
# FIRESTORE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
